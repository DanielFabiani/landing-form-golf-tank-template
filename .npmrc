# ─── Node / pnpm version enforcement ────────────────────────────
# Falla si la versión de Node o pnpm no cumple con "engines" en package.json.
engine-strict=true

# ─── Scripts de instalación ──────────────────────────────────────
# Habilita preinstall / postinstall (necesario para check-deps-age).
enable-pre-post-scripts=true

# Solo los paquetes en "pnpm.onlyBuiltDependencies" (package.json)
# pueden ejecutar scripts de build (install/postinstall).
# Cualquier otro paquete que intente correr scripts de instalación
# será ignorado silenciosamente — mitigación directa de supply chain attacks.
# Lista actual: sharp, esbuild (únicos que lo necesitan legítimamente en Next.js).
# Ver: https://pnpm.io/package_json#pnpmonlybuiltdependencies

# ─── Auditoría automática ────────────────────────────────────────
# Corre `pnpm audit` en cada install y reporta vulnerabilidades conocidas.
audit=true

# ─── Lockfile ────────────────────────────────────────────────────
# En CI usar frozen-lockfile=true para garantizar reproducibilidad.
# prefer-frozen-lockfile advierte si el lockfile está desactualizado
# pero no bloquea en desarrollo.
prefer-frozen-lockfile=true

# ─── Resolución de dependencias ──────────────────────────────────
# No romper el install por peer deps opcionales faltantes.
strict-peer-dependencies=false

# Evita que dependencias transitivas sean accesibles directamente
# desde el código (previene phantom dependency bugs).
shamefully-hoist=false
